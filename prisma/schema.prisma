// THE BUILDER'S HOUSE — Prisma Schema
// PostgreSQL 16 Managed · DigitalOcean
// inventory_movements es APPEND-ONLY: nunca UPDATE ni DELETE

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  VENDOR
  WAREHOUSE
  VIEWER
}

enum MovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum ReferenceType {
  INVOICE
  PURCHASE_ORDER
  ADJUSTMENT
  TRANSFER
  DAMAGE_REPORT
  CYCLE_COUNT
  DIRECT_RECEIPT
}

enum TransferStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIAL
  VOIDED
  PENDING_AUTHORIZATION // factura creada por VENDOR con stock insuficiente — requiere aprobación de MANAGER
  CONVERTED             // QUOTE original después de ser convertida a INVOICE
}

enum InvoiceType {
  INVOICE
  QUOTE
  CREDIT_NOTE
  BALANCE_FORWARD  // Saldo inicial de migración — CXC
}

enum CustomerType {
  RETAIL
  WHOLESALE
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  IN_TRANSIT
  RECEIVED
  CLOSED
}

enum SupplierCountry {
  DO
  PR
  US
}

enum PaymentMethod {
  CASH
  CHECK
  TRANSFER
  CARD
  CREDIT
}

// ─────────────────────────────────────────────────────────────
// USUARIOS Y PERMISOS
// ─────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String
  passwordHash       String?
  role               Role      @default(VENDOR)
  isActive           Boolean   @default(true)
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Auth.js relations
  accounts           Account[]
  sessions           Session[]

  // Business relations
  movements           InventoryMovement[]
  invoicesCreated     Invoice[]           @relation("InvoiceCreatedBy")
  paymentsReceived    Payment[]
  auditLogs           AuditLog[]
  cycleCountsAssigned CycleCount[]
  transfersCreated    Transfer[]          @relation("TransferCreatedBy")
  transfersConfirmed  Transfer[]          @relation("TransferConfirmedBy")
  transfersCancelled  Transfer[]          @relation("TransferCancelledBy")

  @@map("users")
}

// Auth.js required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// INTENTOS DE LOGIN — rate limiting persistente
// ─────────────────────────────────────────────────────────────

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  success   Boolean  @default(false)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("login_attempts")
}

// ─────────────────────────────────────────────────────────────
// CONFIGURACIÓN DEL SISTEMA
// ─────────────────────────────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

// ─────────────────────────────────────────────────────────────
// INVENTARIO
// ─────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  products  Product[]

  @@map("categories")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  country        SupplierCountry @default(DO)
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  paymentTerms   String?
  notes          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model Warehouse {
  id        String    @id @default(cuid())
  name      String    @unique
  address   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  locations     ProductLocation[]
  transfersFrom Transfer[]         @relation("TransferFrom")
  transfersTo   Transfer[]         @relation("TransferTo")

  @@map("warehouses")
}

model Product {
  id             String   @id @default(cuid())
  sku            String   @unique
  barcode        String?  @unique
  qrCode         String?  @unique
  name           String
  description    String?
  categoryId     String
  supplierId     String?
  // Specs
  dimensions     Json?    // { width, height, depth, unit }
  color          String?
  model          String?
  type           String?  // corrediza, batiente, proyectante, fija, puerta
  // Pricing
  unitCost       Decimal  @db.Decimal(12, 2)
  retailPrice    Decimal  @db.Decimal(12, 2)
  wholesalePrice Decimal  @db.Decimal(12, 2)
  // Control
  minStock       Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category       Category          @relation(fields: [categoryId], references: [id])
  supplier       Supplier?         @relation(fields: [supplierId], references: [id])
  locations      ProductLocation[]
  movements      InventoryMovement[]
  invoiceItems   InvoiceItem[]
  purchaseItems  PurchaseOrderItem[]
  cycleCounts    CycleCount[]
  transferLines  TransferLine[]

  @@index([isActive, name])
  @@map("products")
}

model ProductLocation {
  id                 String    @id @default(cuid())
  productId          String
  warehouseId        String
  locationCode       String    // e.g. A-12-03
  quantityOnHand     Int       @default(0)
  reservedQuantity   Int       @default(0)
  // Backorder: units sold (authorized) but not yet physically received.
  // Incremented by authorizeBackorder/authorizeAndPay when onHand < qty.
  // Decremented when a purchase order IN movement arrives and fills the debt.
  backorderQuantity  Int       @default(0)
  updatedAt          DateTime  @updatedAt

  product            Product       @relation(fields: [productId], references: [id])
  warehouse          Warehouse     @relation(fields: [warehouseId], references: [id])
  movements          InventoryMovement[]
  invoiceItems       InvoiceItem[]
  cycleCounts        CycleCount[]

  @@unique([productId, warehouseId])
  @@map("product_locations")
}

// CRÍTICO: APPEND-ONLY. NO UPDATE. NO DELETE.
model InventoryMovement {
  id              String        @id @default(cuid())
  productId       String
  locationId      String
  movementType    MovementType
  quantity        Int           // positivo=entrada, negativo=salida
  referenceType   ReferenceType
  referenceId     String?
  userId          String
  photoUrl        String?
  notes           String?
  // Anti-robo metadata
  gpsLat          Decimal?      @db.Decimal(10, 8)
  gpsLng          Decimal?      @db.Decimal(11, 8)
  deviceFingerprint String?
  ipAddress       String?
  requiresApproval Boolean      @default(false)
  approvedBy      String?       // userId of approver
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  // NO updatedAt — inmutable

  product         Product           @relation(fields: [productId], references: [id])
  location        ProductLocation   @relation(fields: [locationId], references: [id])
  user            User              @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([movementType])
  @@index([productId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
  @@map("inventory_movements")
}

// ─────────────────────────────────────────────────────────────
// VENTAS
// ─────────────────────────────────────────────────────────────

model Customer {
  id                  String       @id @default(cuid())
  code                String       @unique
  name                String
  type                CustomerType @default(RETAIL)
  taxId               String?      // EIN / SSN / RNC
  phone               String?
  email               String?
  address             String?
  municipality        String?
  creditLimit         Decimal      @db.Decimal(12, 2) @default(0)
  currentBalance      Decimal      @db.Decimal(12, 2) @default(0)
  specialPricingTier  String?
  isActive            Boolean      @default(true)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  invoices            Invoice[]

  @@index([isActive, name])
  @@map("customers")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  customerId    String
  type          InvoiceType   @default(INVOICE)
  subtotal      Decimal       @db.Decimal(12, 2)
  taxRate       Decimal       @db.Decimal(5, 4) @default(0.115) // IVU 11.5%
  taxAmount     Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  status        InvoiceStatus @default(DRAFT)
  paidAmount    Decimal       @db.Decimal(12, 2) @default(0)
  paymentTerms  String        @default("CONTADO") // CONTADO | CREDITO
  dueDate       DateTime?
  notes             String?
  sourceQuoteId     String?       // set on INVOICE derived from QUOTE via convertQuoteToInvoice
  sourceInvoiceId   String?       // set on CREDIT_NOTE derived from INVOICE
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  customer          Customer      @relation(fields: [customerId], references: [id])
  createdBy         User          @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  sourceQuote       Invoice?      @relation("QuoteToInvoice", fields: [sourceQuoteId], references: [id])
  convertedInvoices Invoice[]     @relation("QuoteToInvoice")
  sourceInvoice     Invoice?      @relation("InvoiceToCreditNote", fields: [sourceInvoiceId], references: [id])
  creditNotes       Invoice[]     @relation("InvoiceToCreditNote")
  items             InvoiceItem[]
  payments          Payment[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([customerId, status])
  @@index([type])
  @@index([sourceQuoteId])
  @@index([sourceInvoiceId])
  @@map("invoices")
}

model InvoiceItem {
  id                  String           @id @default(cuid())
  invoiceId           String
  productId           String
  locationId          String?          // NULL for QUOTE items; set for INVOICE items (enforced by application)
  quantity            Int
  unitPrice           Decimal          @db.Decimal(12, 2)
  discountPercent     Decimal          @db.Decimal(5, 2) @default(0)
  lineTotal           Decimal          @db.Decimal(12, 2)
  // How many units in this line were authorized as backorder (sold without physical stock).
  // Set by authorizeBackorder/authorizeAndPay when stock was insufficient.
  quantityBackordered Int              @default(0)

  invoice         Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         Product          @relation(fields: [productId], references: [id])
  location        ProductLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("invoice_items")
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod
  reference   String?
  receivedById String
  paidAt      DateTime      @default(now())
  notes       String?

  invoice     Invoice       @relation(fields: [invoiceId], references: [id])
  receivedBy  User          @relation(fields: [receivedById], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// COMPRAS E IMPORTACIÓN (RD → PR)
// ─────────────────────────────────────────────────────────────

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String              @unique
  supplierId      String
  status          PurchaseOrderStatus @default(DRAFT)
  expectedDate    DateTime?
  receivedDate    DateTime?
  freightCost     Decimal             @db.Decimal(12, 2) @default(0)
  customsCost     Decimal             @db.Decimal(12, 2) @default(0)
  totalLandedCost Decimal             @db.Decimal(12, 2) @default(0)
  exchangeRate    Decimal?            @db.Decimal(10, 4) // DOP → USD
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantityOrdered Int
  quantityReceived Int          @default(0)
  unitCostDop     Decimal?      @db.Decimal(12, 2) // Costo en DOP
  unitCostUsd     Decimal       @db.Decimal(12, 2) // Costo en USD

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// ─────────────────────────────────────────────────────────────
// ANTI-ROBO: CONTEO CÍCLICO
// ─────────────────────────────────────────────────────────────

model CycleCount {
  id              String    @id @default(cuid())
  productId       String
  locationId      String?   // ubicación específica a contar (NULL = conteo de todas las ubicaciones)
  assignedUserId  String
  scheduledDate   DateTime
  completedAt     DateTime?
  systemQuantity  Int       // Lo que el sistema dice (por ubicación si locationId != null, total si null)
  countedQuantity Int?      // Lo que el empleado contó
  variance        Int?      // countedQuantity - systemQuantity
  notes           String?
  photoUrl        String?
  createdAt       DateTime  @default(now())

  product         Product          @relation(fields: [productId], references: [id])
  location        ProductLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  assignedUser    User             @relation(fields: [assignedUserId], references: [id])

  @@map("cycle_counts")
}

// ─────────────────────────────────────────────────────────────
// SECUENCIAS — números correlativos atómicos
// ─────────────────────────────────────────────────────────────

model Sequence {
  name         String   @id            // 'INVOICE', 'PURCHASE_ORDER', 'CUSTOMER', 'QUOTE'
  prefix       String                  // 'FAC-', 'OC-RD-', 'CLI-', 'COT-'
  padding      Int      @default(5)    // dígitos del número: FAC-00001 = 5
  currentValue Int      @default(0)    // arranca en 0; primer valor generado = 1
  updatedAt    DateTime @updatedAt

  @@map("sequences")
}

// ─────────────────────────────────────────────────────────────
// AUDITORÍA (inmutable — append-only)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, APPROVE, etc.
  entityType  String   // User, Product, Invoice, etc.
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  // NO updatedAt — inmutable

  user        User     @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────
// TRANSFERENCIAS EN DOS FASES
// ─────────────────────────────────────────────────────────────

model Transfer {
  id              String         @id @default(cuid())
  transferNumber  String         @unique               // TRF-YYYY-NNNN
  status          TransferStatus @default(PENDING)
  fromWarehouseId String
  toWarehouseId   String
  createdById     String
  confirmedById   String?
  cancelledById   String?
  reason          String?
  createdAt       DateTime       @default(now())
  confirmedAt     DateTime?
  cancelledAt     DateTime?

  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  createdBy       User           @relation("TransferCreatedBy", fields: [createdById], references: [id])
  confirmedBy     User?          @relation("TransferConfirmedBy", fields: [confirmedById], references: [id])
  cancelledBy     User?          @relation("TransferCancelledBy", fields: [cancelledById], references: [id])
  lines           TransferLine[]

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("transfers")
}

model TransferLine {
  id         String   @id @default(cuid())
  transferId String
  productId  String
  quantity   Int

  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])

  @@map("transfer_lines")
}
