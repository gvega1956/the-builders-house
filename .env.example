# ─── Base de datos ───────────────────────────────────────────
# PostgreSQL 16 Managed en DigitalOcean
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/builders_house?schema=public"

# ─── Auth.js ─────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="tu-secret-aqui-minimo-32-caracteres"

# ─── DigitalOcean Spaces (S3-compatible) ─────────────────────
# Para fotos de movimientos y PDFs de facturas
DO_SPACES_KEY="tu-key"
DO_SPACES_SECRET="tu-secret"
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_BUCKET="builders-house"
DO_SPACES_REGION="nyc3"

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@buildershouse.pr"

# ─── Inngest (background jobs) ───────────────────────────────
INNGEST_SIGNING_KEY="signkey-xxxxxxxxxxxx"
INNGEST_EVENT_KEY="xxxxxxxxxxxxxxxxxxxx"

# ─── App ─────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"
